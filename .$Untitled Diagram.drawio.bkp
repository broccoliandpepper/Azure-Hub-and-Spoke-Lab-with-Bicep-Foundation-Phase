        <mxCell id="FRNS4a4c-YYo95h02Q12-73" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Current Foundation State&lt;/h1&gt;&lt;p&gt;Hub-VNet (10.0.0.0/16)&lt;/p&gt;&lt;p&gt;├─ GatewaySubnet (10.0.1.0/24)&lt;/p&gt;&lt;p&gt;├─ AzureFirewallSubnet (10.0.2.0/24)&lt;/p&gt;&lt;p&gt;└─ HubMgmtSubnet (10.0.3.0/24)&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Spoke-Public-VNet (172.16.0.0/16)&lt;/p&gt;&lt;p&gt;├─ AppGatewaySubnet (172.16.0.0/24)&lt;/p&gt;&lt;p&gt;└─ WebSubnet (172.16.1.0/24)&lt;/p&gt;&lt;p&gt;&amp;nbsp; &amp;nbsp;├─ NSG: nsg-web-dev&lt;/p&gt;&lt;p&gt;&amp;nbsp; &amp;nbsp;│&amp;nbsp; ├─ Allow TCP 80 from 172.16.0.0/24&lt;/p&gt;&lt;p&gt;&amp;nbsp; &amp;nbsp;│&amp;nbsp; ├─ Allow TCP 443 from 172.16.0.0/24&lt;/p&gt;&lt;p&gt;&amp;nbsp; &amp;nbsp;│&amp;nbsp; └─ Allow TCP 22 from 10.250.0.0/24&lt;/p&gt;&lt;p&gt;&amp;nbsp; &amp;nbsp;└─ Route Table: rt-web-dev&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Spoke-Private-VNet (192.168.0.0/16)&lt;/p&gt;&lt;p&gt;├─ ServerSubnet (192.168.1.0/24)&lt;/p&gt;&lt;p&gt;│&amp;nbsp; ├─ NSG: nsg-server-dev&lt;/p&gt;&lt;p&gt;│&amp;nbsp; │&amp;nbsp; ├─ Allow TCP 8080 from 172.16.1.0/24&lt;/p&gt;&lt;p&gt;│&amp;nbsp; │&amp;nbsp; └─ Allow TCP 22 from 10.250.0.0/24&lt;/p&gt;&lt;p&gt;│&amp;nbsp; └─ Route Table: rt-server-dev&lt;/p&gt;&lt;p&gt;└─ PrivateEndpointSubnet (192.168.2.0/24)&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Peerings&lt;/p&gt;&lt;p&gt;- Hub -&amp;gt; Spoke Public&lt;/p&gt;&lt;p&gt;- Spoke Public -&amp;gt; Hub&lt;/p&gt;&lt;p&gt;- Hub -&amp;gt; Spoke Private&lt;/p&gt;&lt;p&gt;- Spoke Private -&amp;gt; Hub&lt;/p&gt;" vertex="1">
          <mxGeometry height="810" width="300" x="1200" y="190" as="geometry" />
        </mxCell>
